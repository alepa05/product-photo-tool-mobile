:root {
  --bg: #f3f4f6;
  --card: #ffffff;
  --text: #111827;
  --muted: #6b7280;
  --line: #e5e7eb;
  --accent: #111827;
  --accent-2: #2563eb;
  --success: #065f46;
}

* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; }
body {
  font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  background: linear-gradient(180deg, #eef2ff 0%, var(--bg) 20%, var(--bg) 100%);
  color: var(--text);
}

.app-shell {
  max-width: 560px;
  margin: 0 auto;
  padding: 18px 14px 28px;
}

.card {
  background: var(--card);
  border: 1px solid rgba(17, 24, 39, 0.06);
  border-radius: 22px;
  padding: 18px;
  box-shadow: 0 12px 40px rgba(17, 24, 39, 0.08);
  margin-bottom: 14px;
}

.hero-card h1 {
  font-size: 1.7rem;
  margin: 8px 0 6px;
}

.subtitle {
  margin: 0;
  color: var(--muted);
  line-height: 1.45;
}

.badge {
  display: inline-flex;
  padding: 8px 12px;
  border-radius: 999px;
  background: #eef2ff;
  color: #3730a3;
  font-size: 0.82rem;
  font-weight: 700;
}

.field {
  display: block;
  margin-bottom: 16px;
}

.field span {
  display: block;
  font-weight: 700;
  margin-bottom: 8px;
}

input[type="text"],
input[type="file"] {
  width: 100%;
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 14px 14px;
  font-size: 16px;
  background: #fff;
}

.file-field small {
  display: block;
  margin-top: 8px;
  color: var(--muted);
  line-height: 1.35;
}

button,
.download-btn {
  display: inline-flex;
  width: 100%;
  justify-content: center;
  align-items: center;
  min-height: 52px;
  border: 0;
  border-radius: 16px;
  background: var(--accent);
  color: #fff;
  font-size: 1rem;
  font-weight: 700;
  text-decoration: none;
  padding: 14px 18px;
}

button:disabled {
  opacity: 0.6;
}

.preview-wrap {
  margin: 6px 0 16px;
  border: 1px solid var(--line);
  border-radius: 18px;
  overflow: hidden;
  background: #f9fafb;
}

.preview-wrap img {
  width: 100%;
  display: block;
  max-height: 360px;
  object-fit: contain;
}

.status-card {
  border-left: 6px solid var(--accent-2);
}

.result-card h2 {
  margin-top: 0;
  margin-bottom: 8px;
}

.result-card p {
  color: var(--success);
  font-weight: 600;
}

.hidden {
  display: none;
}

@media (min-width: 700px) {
  .app-shell {
    padding-top: 28px;
  }
}
